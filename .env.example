# ─── Environment selector ────────────────────────────────────────────────────
# Controls which .env.<TEST_ENV> file is loaded at runtime.
# Valid values: local | stage | production
# Pass via CLI:  cross-env TEST_ENV=stage npm test
# Or set here for a default (not recommended — prefer CLI).
TEST_ENV=local

# ─── Application URLs ─────────────────────────────────────────────────────────
BASE_URL=https://your-app-host/masar/

# Identity server host — used for ignoreHTTPSErrors when it has a self-signed cert.
IDENTITY_SERVER_URL=https://your-identity-server-host

# ─── Browser settings ─────────────────────────────────────────────────────────
BROWSER=chromium          # chromium | firefox | webkit
HEADED=false              # true to run with a visible browser window
SLOW_MO=0                 # ms delay between Playwright actions (useful for debugging)

# ─── Timeouts & retries ───────────────────────────────────────────────────────
TIMEOUT=60000             # global action/navigation timeout in ms
RETRIES=0                 # number of test retries on failure

# ─── Credentials ──────────────────────────────────────────────────────────────
APP_USERNAME=your_username
APP_PASSWORD=your_password

# ─── Polling exclusion ────────────────────────────────────────────────────────
# Regex pattern for API endpoints the app polls continuously.
# Requests matching this pattern are excluded from the quiet-window check.
POLLING_EXCLUDE_PATTERN=/(heartbeat|ping|health|polling|live|realtime|ws|socket|signalr|hub)/
